# =============================================================================
# SECRETS & ENVIRONMENT  — highest priority, listed first intentionally
# =============================================================================
.env
.env.*
!.env.example          # always allow the safe template
*.pem
*.key
secrets/
credentials.json
service-account*.json

# =============================================================================
# PYTHON / FASTAPI
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
MANIFEST
pip-wheel-metadata/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.lcov

# Type checkers & linters
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json
pyrightconfig.json

# =============================================================================
# NODE / FRONTEND (Vite + Next.js)
# =============================================================================
node_modules/

# Vite
dist/
dist-ssr/
.vite/

# Next.js
.next/
out/

# Build caches
.turbo/
.cache/
*.tsbuildinfo

# Package manager locks — keep one, ignore the others
# (uncomment the one you're NOT using to avoid conflicts)
# yarn.lock
# pnpm-lock.yaml

# Local Vite / CRA env overrides
*.local

# =============================================================================
# REDIS
# =============================================================================
dump.rdb
*.rdb
appendonly.aof
redis.conf.local

# =============================================================================
# PRISMA / POSTGRESQL (future-proofing)
# =============================================================================
# Generated Prisma client goes in node_modules — no extra ignore needed.
# Keep prisma/migrations/ committed. Ignore local dev DB dumps:
*.dump
*.sql.gz
pgdata/

# =============================================================================
# DOCKER OVERRIDES
# =============================================================================
docker-compose.override.yml
docker-compose.*.yml
!docker-compose.yml     # keep the base file
.docker/

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
uvicorn-access.log

# =============================================================================
# OS CLUTTER
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# EDITORS & IDE
# =============================================================================
# VS Code — allow shared settings (extensions, launch configs) but not personal
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.vscode/*.code-workspace

# JetBrains
.idea/
*.iml
*.ipr
*.iws
out/

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln

# Vim / Emacs
*.sw?
*~
\#*\#
.#*
*.orig

# =============================================================================
# MISC TOOLING
# =============================================================================
# Claude Code project memory (local-only, not for sharing)
.claude/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Temporary files
*.tmp
*.temp
*.bak
*.orig
scripts/
memory/