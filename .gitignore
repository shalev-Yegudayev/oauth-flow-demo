# =============================================================================
# SECRETS & ENVIRONMENT  — highest priority, listed first intentionally
# =============================================================================
.env
.env.*
!.env.example          # always allow the safe template (root, backend/, frontend/)
*.pem
*.key
secrets/
credentials.json
service-account*.json

# =============================================================================
# PYTHON / FASTAPI
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
build/
*.egg-info/
*.egg
.eggs/
MANIFEST
pip-wheel-metadata/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.lcov

# Type checkers & linters
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# =============================================================================
# NODE / FRONTEND (Vite)
# =============================================================================
node_modules/

# Build output
dist/
dist-ssr/
out/
.vite/

# TypeScript incremental build cache
*.tsbuildinfo

# Build caches
.turbo/
.cache/

# Local env overrides (e.g. .env.local, vite.config.local.ts)
*.local

# =============================================================================
# REDIS
# =============================================================================
dump.rdb
*.rdb
appendonly.aof
redis.conf.local

# =============================================================================
# DOCKER OVERRIDES
# =============================================================================
docker-compose.override.yml   # standard Docker local-override convention
.docker/

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
uvicorn-access.log

# =============================================================================
# OS CLUTTER
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# EDITORS & IDE
# =============================================================================
# VS Code — allow shared settings (extensions, launch configs) but not personal
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.vscode/*.code-workspace

# JetBrains
.idea/
*.iml
*.ipr
*.iws

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln

# Vim / Emacs
*.sw?
\#*\#
.#*
*.orig

# =============================================================================
# MISC TOOLING
# =============================================================================
# Claude Code project memory (local-only, not for sharing)
.claude/
memory/

# Local-only scripts not intended for the shared codebase
scripts/

# Temporary files
*.tmp
*.temp
*.bak
