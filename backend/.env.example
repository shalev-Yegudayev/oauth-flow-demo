# GitHub OAuth App credentials
# Create at https://github.com/settings/developers → "New OAuth App"
# Callback URL must be: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback
GITHUB_AUTHORIZE_URL=https://github.com/login/oauth/authorize
GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_API_BASE=https://api.github.com
GITHUB_REPOS_PER_PAGE=100

# Internal mock service
INTERNAL_SERVICE_URL=https://internal-service.local
INTERNAL_API_KEY=super-secret-key
INTERNAL_SERVICE_MOCK=true

# Redis
REDIS_URL=redis://localhost:6379/0

# Session encryption — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# For key rotation, comma-separate: primary_key,previous_key (encrypt uses first, decrypt tries all)
SESSION_SECRET=your_fernet_key_here

# CORS / redirect
FRONTEND_ORIGIN=http://localhost:5173
POST_LOGIN_REDIRECT=http://localhost:5173/profile

# "dev" sets Secure=False on cookies (HTTP localhost); "prod" sets Secure=True
ENV=dev

# TTLs (seconds)
SESSION_TTL_SECONDS=3600
STATE_TTL_SECONDS=300
USER_PROFILE_TTL_SECONDS=3600
